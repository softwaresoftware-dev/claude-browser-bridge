{
  "name": "claude-browser-bridge",
  "description": "MCP bridge between Claude Code and your browser via WebSocket extension and shared daemon.",
  "version": "3.2.0",
  "author": {
    "name": "Thatcher",
    "url": "https://github.com/ThatcherT"
  },
  "repository": "https://github.com/ThatcherT/claude-browser-bridge",
  "keywords": [
    "browser",
    "websocket",
    "extension",
    "automation"
  ],
  "mcpServers": {
    "claude-browser-bridge": {
      "command": "node",
      "args": [
        "${CLAUDE_PLUGIN_ROOT}/dist/index.mjs"
      ],
      "cwd": "${CLAUDE_PLUGIN_ROOT}"
    }
  }
}
