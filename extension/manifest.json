{
  "manifest_version": 3,
  "name": "Browser Bridge",
  "version": "1.0.0",
  "description": "MCP bridge for Claude Code browser control",
  "permissions": ["activeTab", "tabs", "scripting", "alarms"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
